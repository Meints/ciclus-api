NODE_ENV=development
PORT=3333

# Database
DATABASE_URL="postgresql://user:password@pooler.supabase.com:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@pooler.supabase.com:5432/database"

# Auth
JWT_SECRET=your-secret-key-min-32-chars-long
JWT_EXPIRES_IN=86400
COOKIE_SECRET=your-cookie-secret
REFRESH_TOKEN_SECRET=your-refresh-secret-min-32-chars-long
REFRESH_TOKEN_EXPIRES_IN=2592000

# CORS
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Rate Limit
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# Logging
LOG_LEVEL=info

# Storage (Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ciclus-uploads

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@ciclus.app

# WhatsApp (Z-API)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io
