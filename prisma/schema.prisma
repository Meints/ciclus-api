generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                String     @id @default(uuid())
  name              String
  document          String?
  logoUrl           String?    @map("logo_url")
  lastServiceNumber Int        @default(0) @map("last_service_number")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  fantasyName       String?    @map("fantasy_name")
  email             String?
  phone             String?
  niche             String     @default("GENERAL")
  plan              String     @default("FREE")
  address           Json?
  isActive          Boolean    @default(true) @map("is_active")
  dataConsentAt     DateTime?  @map("data_consent_at")
  trialEndsAt       DateTime?  @map("trial_ends_at")
  auditLogs         AuditLog[]
  contracts         Contract[]
  customers         Customer[]
  employees         Employee[]
  notifications     Notification[]
  services          Service[]
  users             User[]

  @@index([document])
  @@map("companies")
}

model User {
  id                     String     @id @default(uuid())
  companyId              String     @map("company_id")
  name                   String
  email                  String     @unique
  passwordHash           String     @map("password_hash")
  role                   UserRole   @default(OWNER)
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")
  isActive               Boolean    @default(true) @map("is_active")
  lastLoginAt            DateTime?  @map("last_login_at")
  refreshTokenHash       String?    @map("refresh_token_hash")
  resetPasswordToken     String?    @map("reset_password_token")
  resetPasswordExpiresAt DateTime?  @map("reset_password_expires_at")
  deletedAt              DateTime?  @map("deleted_at")
  auditLogs              AuditLog[]
  notifications          Notification[]
  company                Company    @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("users")
}

model Employee {
  id        String    @id @default(uuid())
  companyId String    @map("company_id")
  name      String
  email     String?
  phone     String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  company   Company   @relation(fields: [companyId], references: [id])
  services  Service[]

  @@index([companyId])
  @@map("employees")
}

model Customer {
  id           String      @id @default(uuid())
  companyId    String      @map("company_id")
  name         String
  email        String?
  phone        String?
  document     String?
  address      Json?
  notes        String?
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")
  fantasyName  String?     @map("fantasy_name")
  documentType String      @default("CNPJ") @map("document_type")
  contracts    Contract[]
  company      Company     @relation(fields: [companyId], references: [id])
  equipment    Equipment[]
  services     Service[]

  @@unique([companyId, document])
  @@index([companyId])
  @@index([companyId, name])
  @@index([companyId, phone])
  @@index([companyId, document])
  @@map("customers")
}

model Contract {
  id              String            @id @default(uuid())
  companyId       String            @map("company_id")
  customerId      String            @map("customer_id")
  frequency       ContractFrequency
  amount          Decimal           @db.Decimal(10, 2)
  startDate       DateTime          @map("start_date")
  endDate         DateTime          @map("end_date")
  nextServiceDate DateTime?         @map("next_service_date")
  status          ContractStatus    @default(ACTIVE)
  notes           String?
  renewCounter    Int               @default(0) @map("renew_counter")
  lastRenewedAt   DateTime?         @map("last_renewed_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")
  company         Company           @relation(fields: [companyId], references: [id])
  customer        Customer          @relation(fields: [customerId], references: [id])
  services        Service[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, nextServiceDate])
  @@map("contracts")
}

model Service {
  id                         String             @id @default(uuid())
  serviceNumber              Int                @map("service_number")
  companyId                  String             @map("company_id")
  contractId                 String?            @map("contract_id")
  customerId                 String             @map("customer_id")
  scheduledAt                DateTime           @map("scheduled_at")
  completedDate              DateTime?          @map("completed_date")
  status                     ServiceStatus      @default(SCHEDULED)
  amount                     Decimal?           @db.Decimal(10, 2)
  isPaid                     Boolean            @default(false) @map("is_paid")
  employeeId                 String?            @map("employee_id")
  notes                      String?
  estimatedDurationMinutes   Int?               @map("estimated_duration_minutes")
  durationMinutes            Int?               @map("duration_minutes")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")
  deletedAt                  DateTime?          @map("deleted_at")
  serviceType                String?            @map("service_type")
  executionNotes             String?            @map("execution_notes")
  reportUrl                  String?            @map("report_url")
  confirmationToken          String?            @unique @map("confirmation_token")
  confirmationTokenExpiresAt DateTime?          @map("confirmation_token_expires_at")
  confirmedAt                DateTime?          @map("confirmed_at")
  confirmedIp                String?            @map("confirmed_ip")
  confirmedUserAgent         String?            @map("confirmed_user_agent")
  confirmedName              String?            @map("confirmed_name")
  confirmedDocument          String?            @map("confirmed_document")
  confirmedDocumentType      String?            @map("confirmed_document_type")
  cancelledReason            String?            @map("cancelled_reason")
  checklistData              Json?              @map("checklist_data")
  equipment                  ServiceEquipment[]
  photos                     ServicePhoto[]
  company                    Company            @relation(fields: [companyId], references: [id])
  contract                   Contract?          @relation(fields: [contractId], references: [id])
  customer                   Customer           @relation(fields: [customerId], references: [id])
  employee                   Employee?          @relation(fields: [employeeId], references: [id])

  @@unique([companyId, serviceNumber])
  @@index([companyId])
  @@index([companyId, scheduledAt])
  @@index([companyId, status])
  @@map("services")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  userId     String?  @map("user_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  createdAt  DateTime @default(now()) @map("created_at")
  company    Company  @relation(fields: [companyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@map("audit_logs")
}

model Equipment {
  id               String             @id @default(uuid())
  companyId        String             @map("company_id")
  customerId       String             @map("customer_id")
  type             String
  brand            String?
  model            String?
  capacity         String?
  serialNumber     String?            @map("serial_number")
  location         String?
  installedAt      DateTime?          @map("installed_at")
  notes            String?
  isActive         Boolean            @default(true) @map("is_active")
  deletedAt        DateTime?          @map("deleted_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  customer         Customer           @relation(fields: [customerId], references: [id])
  serviceEquipment ServiceEquipment[]

  @@index([companyId])
  @@index([customerId])
  @@map("equipment")
}

model ServiceEquipment {
  id          String    @id @default(uuid())
  serviceId   String    @map("service_id")
  equipmentId String    @map("equipment_id")
  notes       String?
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  service     Service   @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, equipmentId])
  @@map("service_equipment")
}

model ServicePhoto {
  id        String   @id @default(uuid())
  serviceId String   @map("service_id")
  url       String
  caption   String?
  createdAt DateTime @default(now()) @map("created_at")
  service   Service  @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
  @@map("service_photos")
}

model Notification {
  id         String    @id @default(uuid())
  companyId  String    @map("company_id")
  userId     String?   @map("user_id")
  type       String
  title      String
  body       String
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  company    Company   @relation(fields: [companyId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])

  @@index([companyId, readAt])
  @@index([userId])
  @@map("notifications")
}

enum ContractFrequency {
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

enum ContractStatus {
  ACTIVE
  ABOUT_TO_EXPIRE
  EXPIRED
  CANCELLED
  PAUSED
}

enum ServiceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NOT_FOUND
  RESCHEDULED
  CONFIRMED
}

enum UserRole {
  SUPERADMIN
  OWNER
  ADMIN
  TECHNICIAN
}
